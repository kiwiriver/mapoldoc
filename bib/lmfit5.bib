@Article{Gao:2000aa,
  author    = {Bo-Cai Gao and Marcos J. Montes and Ziauddin Ahmad and Curtiss O. Davis},
  title     = {Atmospheric correction algorithm for hyperspectral remote sensing of ocean color from space},
  journal   = {Applied Optics},
  year      = {2000},
  volume    = {39},
  number    = {6},
  pages     = {887--896},
  month     = {Feb},
  abstract  = {Existing atmospheric correction algorithms for multichannel remotesensing of ocean color from space were designed for retrievingwater-leaving radiances in the visible over clear deep ocean areas andcannot easily be modified for retrievals over turbid coastalwaters. We have developed an atmospheric correction algorithm forhyperspectral remote sensing of ocean color with the near-futureCoastal Ocean Imaging Spectrometer. The algorithm uses lookuptables generated with a vector radiative transfer code. Aerosolparameters are determined by a spectrum-matching technique that useschannels located at wavelengths longer than 0.86 {\textmu}m. Theaerosol information is extracted back to the visible based on aerosolmodels during the retrieval of water-leaving radiances. Quitereasonable water-leaving radiances have been obtained when ouralgorithm was applied to process hyperspectral imaging data acquiredwith an airborne imaging spectrometer.},
  doi       = {10.1364/AO.39.000887},
  file      = {:/Users/mgao1/OneDrive - NASA/Papers/Jabref/Gao2000_AO_AC.pdf:PDF},
  keywords  = {Atmospheric scattering; Oceanic optics ; Remote sensing and sensors ; Spectroscopy, visible; Atmospheric correction; Atmospheric scattering; Hyperspectral imaging; Imaging spectroscopy; Remote sensing; Spectral imaging},
  publisher = {OSA},
  url       = {http://ao.osa.org/abstract.cfm?URI=ao-39-6-887},
}

