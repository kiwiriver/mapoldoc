@Article{Landgraf:2001aa,
  author   = {Landgraf, Jochen and Hasekamp, Otto P. and Box, Michael A. and Trautmann, Thomas},
  journal  = {Journal of Geophysical Research: Atmospheres},
  title    = {A linearized radiative transfer model for ozone profile retrieval using the analytical forward-adjoint perturbation theory approach},
  year     = {2001},
  number   = {D21},
  pages    = {27291-27305},
  volume   = {106},
  abstract = {For the retrieval of ozone profiles from space-borne radiance measurements, a new linearized radiative transfer model LIRA is presented. The model enables an effective linearization of the reflectance at the top of the atmosphere with respect to both the ozone density in the different layers of the model atmosphere and the Lambertian surface albedo in the UV of the solar spectrum. The linearization of the model is based on the forward-adjoint perturbation theory, where the forward and adjoint solution of the scalar radiative transfer equation in its plane-parallel form are achieved by employing the Gauss-Seidel iteration technique. For clear sky and aerosol-loaded atmospheres the model provides the reflectance as well as its derivatives with respect to ozone density with an accuracy of better than 0.02\%. The derivatives with respect to surface reflection can be calculated with an error of less than 0.05\%. The suitability of the model for ozone profile retrieval is demonstrated. Therefore ozone profiles are retrieved from 156 modeled radiance measurements, simulating real radiance measurements of the Global Ozone Monitoring Experiment (GOME) spectrometer in the UV. The comparison of the retrieved profiles using the proposed model LIRA with a reference retrieval shows small deviations in the stratosphere and upper troposphere of less than 1\% and tolerable differences in the middle and lower troposphere of up to 10\% in the mean profile at ground level.},
  doi      = {10.1029/2001JD000636},
  eprint   = {https://agupubs.onlinelibrary.wiley.com/doi/pdf/10.1029/2001JD000636},
  file     = {:/Users/mgao1/OneDrive - NASA/Papers/Jabref/Landgraf2001_JGRA_LINTRAN.pdf:PDF},
  groups   = {RT and Emulator, adjoint},
  url      = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/2001JD000636},
}

@Article{HASEKAMP2002221,
  author   = {O.P. Hasekamp and J. Landgraf},
  journal  = {Journal of Quantitative Spectroscopy and Radiative Transfer},
  title    = {A linearized vector radiative transfer model for atmospheric trace gas retrieval},
  year     = {2002},
  issn     = {0022-4073},
  number   = {2},
  pages    = {221 - 238},
  volume   = {75},
  abstract = {We present a plane parallel radiative transfer model for polarized light, that provides the intensity vector as well as the derivatives of the four Stokes parameters with respect to atmospheric trace gas profiles. These derivatives are essential for retrieval of height resolved trace gas information from satellite measurements of backscattered sunlight. The model uses the Gauss–Seidel iteration technique for solving the radiative transfer equation. For the first time, the forward-adjoint radiative perturbation theory is applied for the linearization of a radiative transfer model including polarization. The accuracy of the model is better than 0.025% for all four Stokes parameters and better than 0.03% for the derivatives.},
  doi      = {https://doi.org/10.1016/S0022-4073(01)00247-3},
  file     = {:/Users/mgao1/OneDrive - NASA/Papers/Jabref/Hasekamp2002_JQRST_LINTRAN.pdf:PDF},
  groups   = {adjoint},
  keywords = {Radiative transfer, Polarization, Linearization, Perturbation theory, Remote sensing},
  url      = {http://www.sciencedirect.com/science/article/pii/S0022407301002473},
}

