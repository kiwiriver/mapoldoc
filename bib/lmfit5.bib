  keywords  = {Mie theory; Scattering, particles; Atmospheric measurement; Extinction coefficients; Light properties; Light scattering; Multiple scattering; Particle scattering},
  publisher = {OSA},
  url       = {http://opg.optica.org/ol/abstract.cfm?URI=ol-36-22-4464},
}

